{
  "description": "Academic Git hooks — enforce branch protection, gate checks, and clean-room PR creation",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-runner.sh ${CLAUDE_PLUGIN_ROOT}/skills/git-firewall --block",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-runner.sh ${CLAUDE_PLUGIN_ROOT}/skills/branch-lock --block",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "create_pr",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-runner.sh ${CLAUDE_PLUGIN_ROOT}/skills/review-pr --block",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "commit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-runner.sh ${CLAUDE_PLUGIN_ROOT}/skills/commit",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "merge_pr",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-runner.sh ${CLAUDE_PLUGIN_ROOT}/skills/post-merge",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-runner.sh ${CLAUDE_PLUGIN_ROOT}/skills/begin",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/auto-commit.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-runner.sh ${CLAUDE_PLUGIN_ROOT}/skills/begin",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
