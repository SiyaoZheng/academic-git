{
  "description": "ScholarOS Codex hooks for issue-driven research workflows.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${SCHOLAROS_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-.}}/hooks/codex/session-start.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"${SCHOLAROS_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-.}}/hooks/hook-runner.sh\" \"${SCHOLAROS_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-.}}/skills/os-noise-guard\"",
            "timeout": 20,
            "statusMessage": "Cleaning OS metadata noise"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${SCHOLAROS_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-.}}/hooks/codex/user-prompt-submit.sh\"",
            "timeout": 20,
            "statusMessage": "Routing ScholarOS issue workflow"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${SCHOLAROS_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-.}}/hooks/codex/guard-issue-start-route.py\"",
            "timeout": 10,
            "statusMessage": "Checking guard-issue-start-route"
          },
          {
            "type": "command",
            "command": "bash \"${SCHOLAROS_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-.}}/hooks/codex/pretool-bash.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"${SCHOLAROS_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-.}}/hooks/hook-runner.sh\" \"${SCHOLAROS_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-.}}/skills/guard-write-office-source\" --block",
            "timeout": 10,
            "statusMessage": "Checking guard-write-office-source"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${SCHOLAROS_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-.}}/hooks/hook-runner.sh\" \"${SCHOLAROS_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-.}}/skills/merge-pr\" --block",
            "timeout": 10,
            "statusMessage": "Checking ScholarOS merge-pr preflight"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${SCHOLAROS_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-.}}/hooks/codex/finalize-commit.sh\"",
            "timeout": 10,
            "statusMessage": "Running finalize-commit"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${SCHOLAROS_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-.}}/hooks/hook-runner.sh\" \"${SCHOLAROS_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-.}}/skills/finalize-pr-merge\"",
            "timeout": 10,
            "statusMessage": "Running finalize-pr-merge"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${SCHOLAROS_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-.}}/hooks/codex/audit-issue-start-route.py\"",
            "timeout": 30,
            "statusMessage": "Auditing issue-start repair path"
          },
          {
            "type": "command",
            "command": "SCHOLAROS_OS_NOISE_STRICT=true bash \"${SCHOLAROS_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-.}}/hooks/hook-runner.sh\" \"${SCHOLAROS_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-.}}/skills/os-noise-guard\" --block",
            "timeout": 20,
            "statusMessage": "Cleaning OS metadata noise"
          },
          {
            "type": "command",
            "command": "bash \"${SCHOLAROS_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-.}}/hooks/codex/stop.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
