{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/siyaozheng/plugins/academic-git/hooks/codex/session-start.sh'",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/siyaozheng/plugins/academic-git/hooks/codex/pretool-bash.sh'",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/siyaozheng/plugins/academic-git/hooks/codex/posttool-commit.sh'",
            "timeout": 10,
            "statusMessage": "Checking academic-git commit context"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/siyaozheng/plugins/academic-git/hooks/codex/stop.sh'",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
